{
  "name": "python",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/python",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": ".venv\\Scripts\\python.exe run.py",
        "cwd": "apps/python"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": ".venv\\Scripts\\python.exe run.py",
        "cwd": "apps/python"
      }
    },
    "docker": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "docker build -t experiment-nx-python -f apps/python/Dockerfile apps/python"
        ]
      },
      "dependsOn": []
    }
  }
}
